---
import MainLayout from '../layouts/MainLayout.astro'
---

<MainLayout title="Kontak - iGrow Smart Learning Center">

	<!-- NAVBAR -->
<nav class="fixed top-0 left-0 w-full z-50 bg-white/80 backdrop-blur-xl border-b border-slate-100">

  <div class="max-w-7xl mx-auto px-6 py-5 flex items-center justify-between">

    <!-- LOGO -->
    <div class="flex items-center gap-3">

      <img
        src="/logo.jpeg"
        alt="logo"
        class="w-16"
      />

    </div>

    <!-- MENU -->
    <div class="hidden md:flex items-center gap-10 font-bold text-slate-700">

      <a href="/" class="hover:text-green-500 transition">
        Beranda
      </a>

      <a href="/#about" class="hover:text-green-500 transition">
        Tentang Kami
      </a>

      <a href="/#program" class="hover:text-green-500 transition">
        Program
      </a>

      <a href="/testimoni" class="hover:text-green-500 transition">
        Testimoni
      </a>

      <a href="/contact" class="hover:text-green-500 transition">
        Kontak
      </a>

    </div>

    <!-- BUTTON -->
    <a
      href="https://wa.me/628123456789"
      class="bg-green-500 hover:bg-green-600 transition text-white px-6 py-3 rounded-2xl font-bold shadow-lg shadow-green-200"
    >
      Hubungi Kami
    </a>

  </div>

</nav>

  <section class="min-h-screen bg-gradient-to-b from-sky-50 to-white py-32">

    <div class="max-w-7xl mx-auto px-6">

      <div class="text-center max-w-2xl mx-auto">

        <div class="inline-block bg-green-100 text-green-600 px-4 py-2 rounded-full font-bold mb-6">
          📞 Hubungi Kami
        </div>

        <h1 class="text-6xl font-black text-slate-800 leading-tight">
          Konsultasikan
          Kebutuhan Belajar
          Anak Anda
        </h1>

        <p class="mt-8 text-slate-600 text-xl leading-relaxed">
          Kami siap membantu memberikan solusi belajar terbaik
          untuk putra dan putri Anda.
        </p>

      </div>

      <div class="grid md:grid-cols-2 gap-12 mt-20">

        <!-- LEFT -->
        <div class="bg-white rounded-[40px] p-10 shadow-xl border border-slate-100">

          <h2 class="text-3xl font-black text-slate-800 mb-10">
            Informasi Kontak
          </h2>

          <div class="space-y-8">

            <div class="flex items-start gap-5">
              <div class="w-16 h-16 rounded-2xl bg-green-100 flex items-center justify-center text-3xl">
                📍
              </div>

              <div>
                <h3 class="font-black text-xl text-slate-800">
                  Alamat
                </h3>

                <p class="text-slate-600 mt-2 leading-relaxed">
                  Jl. Pendidikan No. 12,
                  Kota Anda
                </p>
              </div>
            </div>

            <div class="flex items-start gap-5">
              <div class="w-16 h-16 rounded-2xl bg-sky-100 flex items-center justify-center text-3xl">
                📞
              </div>

              <div>
</MainLayout>